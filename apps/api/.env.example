APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/auto_trade
REDIS_URL=redis://localhost:6379/0

# Generate with:
# python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('123456'))"
OWNER_PASSWORD_HASH=REPLACE_WITH_ARGON2_HASH

SESSION_COOKIE_NAME=auto_trade_session
SESSION_TTL_MINUTES=120
SESSION_SECURE_COOKIE=false
SESSION_SAMESITE=lax

LOGIN_RATE_LIMIT_MAX_REQUESTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_DURATION_SECONDS=900

CORS_ORIGINS=http://localhost:5173

AUTO_CREATE_SCHEMA=true
